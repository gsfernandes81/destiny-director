# Discord control server config
CONTROL_DISCORD_SERVER_ID=1000000000000000000
CONTROL_DISCORD_ROLE_ID=1000000000000000000
KYBER_DISCORD_SERVER_ID=1000000000000000000
LOG_CHANNEL_ID=1000000000000000000
ALERTS_CHANNEL_ID=1000000000000000000


# Discord environment config
DISCORD_TOKEN_ANCHOR=fv4vwjn34jgvjsglmlers
DISCORD_TOKEN_BEACON=fv4vwjn34jgvjsglmlers
TEST_ENV=1000000000000000000,1000000000000000001
DISABLE_BAD_CHANNELS=True

# Discord constants
EMBED_DEFAULT_COLOR=0xEC42A5
EMBED_ERROR_COLOR=0xEF323F
# Each key is a followable (anchor-posted, beacon-mirrored) announce channel id.
# "portal_ops" is the Portal Ops daily autopost — replace the 0 placeholder with the
# real announce channel id to bring it online; while it is 0/absent the Portal Ops
# autopost + command load dormant and post nothing. "iron_banner" behaves the same way
# (its producer/command are skipped while 0/absent) — set it to the environment's Iron
# Banner announce channel id (dev and prod differ).
FOLLOWABLES='{"ada": 1057069801555628072, "twab": 1075858178056658994, "prime": 1022788432717693029, "nwid": 1055920679167459428, "lost_sector": 864935509229699084, "daily_reset": 783898898657312828, "eververse": 1049748068389621931, "weekly_reset": 615429125955387392, "trials": 775806852142989373, "xur": 775807486066032700, "portal_ops": 0, "iron_banner": 0}'

# Discord logging / alerting
ALERT_MIN_LEVEL=ERROR

DEFAULT_URL="https://kyberscorner.com/"

# Database. MYSQL_PRIVATE_URL is preferred over MYSQL_URL when both are set.
MYSQL_PRIVATE_URL=mysql://username:password@hostname/dbname
MYSQL_URL=mysql://username:password@hostname/dbname
# In case you are using a MYSQL instance without ssl set the below
# MYSQL_SSL=false

# Webserver port (Bungie OAuth callback + rotation editor); defaults to 8080
PORT=8080

# Public origin the anchor web app is reachable at, used to mint rotation-editor links.
# On Railway this is derived from RAILWAY_PUBLIC_DOMAIN automatically; set this only to
# override (e.g. a custom domain). Scheme required; no trailing slash.
# PUBLIC_BASE_URL=https://anchor.example.com

# Static Images / Resources
LOST_SECTOR_GIF_URL="https://www.example.com"
XUR_IMAGE_URL="https://www.example.com"

# Bungie Credentials

BUNGIE_API_KEY="uewhfhewfuojewiofjeiowfjew"
BUNGIE_CLIENT_ID=438481
BUNGIE_CLIENT_SECRET="fjruwifhuewjfeiwjfeuiw-fehwuofj"

# Discord OAuth for the anchor web UI (rotation editor + weekly-reset form).
# CLIENT_ID is the bot's application id; CLIENT_SECRET is from the Developer Portal's
# OAuth2 tab (NOT the bot token). Register the redirect {PUBLIC_BASE_URL}/auth/callback
# under Portal -> OAuth2 -> Redirects. Both may be left blank for local dev without a
# tunnel (the /auth/login route then surfaces a clear error).
DISCORD_OAUTH_CLIENT_ID=438481
DISCORD_OAUTH_CLIENT_SECRET="fjruwifhuewjfeiwjfeuiw-fehwuofj"
# Dev-only auth bypass for the web UI: a Discord user id treated as an authenticated
# owner so you can hit the editors without the OAuth round-trip. Honored ONLY when
# TEST_ENV is set AND there is no PUBLIC_BASE_URL (i.e. local dev without a tunnel) — so
# it stays inert on the internet-facing dev/prod deploys. Leave unset unless doing local dev.
# DEV_AUTH_USER_ID=1000000000000000000

# Pi dev container: the Pi HOST user's .ssh directory, bind-mounted read-only so the
# in-container sshd (Zed-remote, port 2222) authorizes the same keys. Its authorized_keys
# must list the pubkey(s) that will connect (e.g. Zed's).
DEV_SSH_AUTHORIZED_KEYS=/home/<pi-user>/.ssh/

# Host port mapped to the in-container sshd (defaults to 2222). Change it if 2222 is
# taken on the Pi host or you run more than one dev container. The container side stays
# 2222; point Zed / the Cloudflare tunnel at whatever you set here.
# DEV_SSH_PORT=2222
